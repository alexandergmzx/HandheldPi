# HandheldPi device configuration — copy to /etc/hht/hht.toml and edit per unit.
# Every deployment-specific value lives here; the code hardcodes nothing.

[device]
id = "HHT-PI-01"        # must match a registered, active device_code in the WMS
site = "MAD-01"         # `device` table (uppercase). Seeded dev device: HHT-PI-01.

[wms]
backend = "http"        # http | mock
base_url = "http://192.168.1.50:8080"  # WMS LAN address; see the WMS runbooks
timeout_s = 5.0         # per-request timeout                (docs/runbook-*.md §3-4)
retry_interval_s = 30.0 # offline-queue retry / connectivity probe period

[scanner]
backend = "camera"      # camera | mock (mock = scans injected by keyboard/script)
debounce_s = 2.0        # suppress identical payload re-reads within this window
frame_size = [640, 480] # lores decode stream
af_mode = "continuous"  # continuous | manual  (Camera Module 3)
lens_position = 6.6     # dioptres (~15 cm) when af_mode = "manual"
feedback_s = 1.5        # dwell time of the on-screen last-decode readout line
accept_flash_s = 0.1    # screen-invert flash on an accepted scan (silent-mode cue)

[display]
backend = "framebuffer" # framebuffer | console | image
fb_device = "auto"      # "auto" finds the mipi-dbi panel, or e.g. "/dev/fb1"
rotation = 0            # 0 | 90 | 180 | 270 (CW, applied before blit)

[input]
backend = "gpio"        # gpio | keyboard
hold_start_s = 1.5      # hold Start this long to log out

[audio]
backend = "alsa"        # alsa | none (audio failure never blocks the workflow)
# GamePi20 PWM audio appears as the bcm2835 "Headphones" card after setup_audio.sh.
# Keep this explicit so a connected HDMI display cannot steal the sound output.
device = "plughw:CARD=Headphones,DEV=0"
sounds_dir = "assets/sounds"
queue_size = 8           # bounded: old cues are dropped rather than delaying scans

# GamePi20 button map, BCM numbering, active-low with internal pull-ups.
# Verified against Waveshare's mk_arcade_joystick_rpi RetroPie config; re-check in
# Phase 0 with `python -m hht.tools.buttontest` (board revisions may differ).
[input.pins]
up = 12
down = 20
left = 21
right = 13
start = 26
select = 16
a = 23
b = 4
x = 22
y = 17
l = 5
r = 6

[workflow]
error_banner_s = 2.5    # error / confirmation banner display time
pin_length = 4          # must equal the picker account's numeric password length

[logging]
file = "/var/log/hht/hht.jsonl"  # JSON-lines, one event per line
level = "INFO"
max_bytes = 1048576
backup_count = 5

[queue]
db_path = "/var/lib/hht/queue.db" # persistent offline operation queue (sqlite)

[mock]                  # only used when wms.backend = "mock"
tasks_file = ""         # optional JSON fixture; empty = built-in sample tasks
operators = ["picker01:Picker One:1234", "picker02:Picker Two:5678"]  # username:name:pin
